{
  "name": "@vega/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply vega-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply vega-db --remote",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vega/shared-types": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260606.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "wrangler": "^4.98.0"
  }
}
