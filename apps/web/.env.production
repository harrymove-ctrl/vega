# Production build-time public config (NEXT_PUBLIC_* are inlined into the
# browser bundle at build time). Committed so the Cloudflare Workers Builds
# rebuild picks them up — there are NO secrets here.
#
# Cutover: point the deployed frontend at the live vega-api worker and turn off
# the no-backend demo stub so every /api/* call reaches the real backend.
# Rollback: set NEXT_PUBLIC_DEMO_MODE=1 (or revert this file) and rebuild.
NEXT_PUBLIC_API_BASE_URL=https://vega-api.petlofi.workers.dev
NEXT_PUBLIC_DEMO_MODE=0
